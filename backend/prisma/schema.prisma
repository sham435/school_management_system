// ==================== QA EVALUATION ====================

enum QAScoreLevel {
  URGENT_DEVELOPMENT // 1 - விரைவாக அபிவிருத்தி
  NEEDS_DEVELOPMENT   // 2 - அபிவிருத்தி தேவை
  AVERAGE             // 3 - சாதாரணம்
  GOOD                // 4 - நன்று
  VERY_GOOD           // 5 - மிகவும் நன்று
  OUTSTANDING         // 6 - அதிவிசேடம்
}

enum QAStatus {
  DRAFT
  IN_PROGRESS
  COMPLETED
  SUBMITTED
}

model QAEvaluation {
  id            String     @id @default(uuid()) @db.Uuid
  tenantId      String     @db.Uuid
  academicYearId String?    @db.Uuid
  evaluatorId   String?    @db.Uuid
  status        QAStatus   @default(DRAFT)
  totalScore    Decimal?   @db.Decimal(5, 2)
  percentage    Decimal?   @db.Decimal(5, 2)
  grade         String?
  language      String     @default("ta") // ta (Tamil), en (English)
  observations  Json?       @db.Json
  recommendations Json?    @db.Json
  submittedAt   DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  tenant       Tenant              @relation(fields: [tenantId], references: [id])
  academicYear AcademicYear?       @relation(fields: [academicYearId], references: [id])
  evaluator    User?               @relation(fields: [evaluatorId], references: [id])
  criteria     QACriteriaResponse[]

  @@index([tenantId, status])
  @@index([tenantId, academicYearId])
}

model QACriteriaResponse {
  id              String       @id @default(uuid()) @db.Uuid
  evaluationId    String       @db.Uuid
  groupId         String       // QA Group ID (1-8)
  groupName       String       // QA Group Name
  criteriaId      String       // Criteria ID within group
  criteriaName    String
  indicatorId     String?      // Optional indicator
  score           Int          // 1-6
  scoreLabel      String       // Tamil/English label
  discussion      String?      @db.Text
  evidence        String?      @db.Text
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  evaluation QAEvaluation @relation(fields: [evaluationId], references: [id], onDelete: Cascade)

  @@unique([evaluationId, groupId, criteriaId])
  @@index([evaluationId])
}
